PORT=3000

# Optional but strongly recommended for reliable cross-city calls:
# Set these to your own coturn server (self-hosted = no paid API dependency).
# TURN_URLS supports comma-separated values.
# Example:
# TURN_URLS=turn:your-domain.com:3478,turns:your-domain.com:5349
# TURN_USERNAME=your_turn_username
# TURN_CREDENTIAL=your_turn_password
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
